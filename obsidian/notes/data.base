formulas:
  formula: ""
views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder == "notes"
        - file.ext != "base"
    order:
      - file.name
      - date
      - tags
      - entrytitle
      - folder
    sort:
      - property: date
        direction: ASC
      - property: formula.formula
        direction: DESC
    limit: 20
